# 从 @BotFather 获取
BOT_TOKEN=1234567890:replace_with_your_bot_token

# 多个管理员用英文逗号分隔
ADMIN_IDS=123456789

# 要求用户全部加入的群/频道。支持 -100 开头的数字 ID 或 @username
REQUIRED_CHAT_IDS=@your_channel

# 与 REQUIRED_CHAT_IDS 一一对应，多个值用英文逗号分隔
REQUIRED_JOIN_URLS=https://t.me/your_channel
REQUIRED_CHAT_NAMES=通知频道

INVITE_REWARD=5
# 每位邀请人每天最多获得多少次邀请奖励；0 表示不限制
INVITE_DAILY_REWARD_LIMIT=20
CHECKIN_REWARD=1
LOTTERY_COST=5
VERIFY_COOLDOWN_SECONDS=15
VERIFY_MAX_CONCURRENCY=5
REDEMPTION_INTENT_TTL_SECONDS=600
TIMEZONE=Asia/Shanghai
DATABASE_PATH=data/bot.db
