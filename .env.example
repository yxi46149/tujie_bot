# 从 @BotFather 获取
BOT_TOKEN=1234567890:replace_with_your_bot_token

# 多个管理员用英文逗号分隔
ADMIN_IDS=123456789

# 要求用户全部加入的群/频道。支持 -100 开头的数字 ID 或 @username
REQUIRED_CHAT_IDS=@your_channel

# 主菜单“加入通知频道”按钮打开的地址
REQUIRED_JOIN_URL=https://t.me/your_channel

INVITE_REWARD=5
CHECKIN_REWARD=1
TIMEZONE=Asia/Shanghai
DATABASE_PATH=data/bot.db

